{
  "buildCommand": "pnpm --filter @workspace/snapvault run build",
  "outputDirectory": "dist/public",
  "installCommand": "pnpm install",
  "routes": [
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ]
}
